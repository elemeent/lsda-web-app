<div align="center" style="background-color:#17181f;color:#cbcbcb;font-size:14px;">
	<table border="0" cellpadding="0" cellspacing="0" style="border-collapse:collapse;border-spacing:0px;border:none;">
		<tbody>
			<tr>
				<td style="padding:0in 0.25in;" valign="top" width="721">
					<p>
						&nbsp;
					</p>

					<p>
						&nbsp;
					</p>

					<p>
						<span style="font-size:16px;">{{nl2br opening}}</span>
					</p>

					<p>
						&nbsp;
					</p>

					<p>
						&nbsp;
					</p>

					{{#each sections}}
					<p style="text-align:center;">
						<span style="font-size:20px; text-transform:uppercase"><strong><u>{{toRoman (math @index "+" 1)}}. {{this.title}}</u></strong></span>
					</p>

					<p style="text-align:center;">
						&nbsp;
					</p>

					<p>
						<span style="font-size:16px;">{{nl2br this.body}}</span>
					</p>

					<p>
						&nbsp;
					</p>

					<p>
						&nbsp;
					</p>

					{{/each}}

					<hr>
					<p>
						&nbsp;
					</p>

					<p>
						Respectfully Submitted on the <u>{{getOrdinal filingDate.day}}</u> day of <u>{{filingDate.month}}</u>, <u>{{filingDate.year}}</u>.
					</p>

					<p>
						&nbsp;
					</p>

					<p style="font-size:14px;text-align:right;">
						<span><u><span style="font-size:16px; text-transform:uppercase"><em>/s/&nbsp;</em>{{undersigned.name}}</span></u></span>
					</p>

					<p style="font-size:14px;text-align:right;">
						<span style="font-size:16px;">{{undersigned.name}}</span>
					</p>

					<p style="font-size:13px;text-align:right;">
						<span><span style="font-size:16px;">San Andreas State Bar No. {{undersigned.stateBar}}</span></span>
					</p>

					{{#if undersigned.showFirm}}
					<p style="font-size:13px;text-align:right;">
						<span><span style="font-size:16px;">{{undersigned.firm}}</span></span>
					</p>

					{{#if undersigned.showAddress}}
					<p style="font-size:13px;text-align:right;">
						<span><span style="font-size:16px;">{{undersigned.address}}</span></span>
					</p>
					{{/if}}
					{{/if}}

					<p style="font-size:13px;text-align:right;">
						<span><span style="font-size:16px;">{{undersigned.role}}</span></span>
					</p>

					<p style="font-size:13px;">
						(( Tag Involved Parties Here ))
					</p>
				</td>
			</tr>
		</tbody>
	</table>
</div>
