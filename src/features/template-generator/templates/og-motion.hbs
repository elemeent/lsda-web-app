												<span><span style="font-size:20px;text-transform:uppercase;"><b>{{this.name}},</b></span></span>
											</p>
											{{/each}}

											<p style="text-align:right;">
												<span><span style="font-size:20px;"><b>{{defendantLabel}}.</b></span></span><br>
												<br>
												&nbsp;
											</p>
										</td>
										<td style="padding:0in 5.4pt;" valign="top" width="302">
											<p style="text-align:center;">
												<span><span style="font-size:20px;">&nbsp;<span style="vertical-align:baseline;">Case No. [{{lastTwo filingDate.year}}GJ{{#if isCriminal}}CR{{else}}CC{{/if}}{{zeroFill caseNumber 5}}]</span></span></span>
											</p>

											<p style="text-align:center;">
												&nbsp;
											</p>

											<p style="text-align:center;">
												&nbsp;
											</p>

											<p style="text-align:center;">
												&nbsp;
											</p>

											<p style="text-align:center;">
												&nbsp;
											</p>

											<p style="text-align:center;">
												<span style="font-size:20px;"><strong>{{motionTitle}}</strong></span>
											</p>

											<p style="text-align:center;">
												&nbsp;
											</p>

											<p style="text-align:center;">
												&nbsp;
											</p>

											<p style="text-align:center;">
												&nbsp;
											</p>

											<p style="text-align:center;">
												<br>
												<em><span><span style="font-size:20px;"><span style="vertical-align:baseline;">&nbsp;Filed on: {{filingDate.month}} {{getOrdinal filingDate.day}}, {{filingDate.year}}</span></span></span></em>
											</p>

											<p dir="ltr">
												<span><span style="font-size:20px;"><b><span style="vertical-align:baseline;">&nbsp; &nbsp; &nbsp; &nbsp; &nbsp; &nbsp; &nbsp; &nbsp;</span></b></span></span>
											</p>
										</td>
									</tr>
								</tbody>
							</table>
						</div>
					</div>
				</td>
				<td height="58" style="border:none;" width="0">
