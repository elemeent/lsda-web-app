<p style="background-color:#ffffff; color:#555555; font-size:13px; text-align:center">
	<span><span style="font-size:16px"><strong>II. MOTION</strong></span></span>
</p>

<p style="background-color:#ffffff; color:#555555; font-size:13px; text-align:center">
	&nbsp;
</p>

<p style="background-color:#ffffff; color:#555555; font-size:14px; text-align:start">
	<span><span style="font-size:14px">The People, by and through&nbsp;<b>{{prosecutor.name}}</b>, {{prosecutor.rank}} for the County of Los Santos, hereby move this Court to dismiss the charges against the Defendant&nbsp;<em>without&nbsp;</em>prejudice, for the following reasons:</span></span>
</p>

<p style="background-color:#ffffff; color:#555555; font-size:14px; text-align:start">
	&nbsp;
</p>

<ul style="background-color:#ffffff; color:#555555; font-size:13px; text-align:start">
	{{#if dismissal.lackOfCorpus}}
	<li>
		<span><span style="font-size:14px">Lack of Corpus</span></span>
	</li>
	{{/if}}
	{{#if dismissal.lackOfSufficientEvidence}}
	<li>
		<span><span style="font-size:14px">Lack of Sufficient Evidence</span></span>
	</li>
	{{/if}}
	{{#if dismissal.inadmissibleSearchSeizure}}
	<li>
		<span><span style="font-size:14px">Inadmissible Search/Seizure</span></span>
	</li>
	{{/if}}
	{{#if dismissal.victimUnavailable}}
	<li>
		<span><span style="font-size:14px">Victim Unavailable/Declines to Testify</span></span>
	</li>
	{{/if}}
	{{#if dismissal.witnessUnavailable}}
	<li>
		<span><span style="font-size:14px">Witness Unavailable/Declines to Testify</span></span>
	</li>
	{{/if}}
	{{#if dismissal.interestOfJustice}}
	<li>
		<span><span style="font-size:14px">Interest of Justice</span></span>
	</li>
	{{/if}}
	{{#if dismissal.prosecutorPrefilingDeferral}}
	<li>
		<span><span style="font-size:14px">Prosecutor Prefiling Deferral</span></span>
	</li>
	{{/if}}
	{{#if dismissal.furtherInvestigation}}
	<li>
		<span><span style="font-size:14px">Further Investigation</span></span>
	</li>
	{{/if}}
	{{#if dismissal.otherReasoning}}
	<li>
		<span><span style="font-size:14px">Other Reasoning: <u>{{dismissal.otherReasoningObservation}}</u></span></span>
	</li>
	{{/if}}
</ul>

<p style="background-color:#ffffff; color:#555555; font-size:14px; text-align:start">
	&nbsp;
</p>

<hr style="background-color:#ffffff; color:#555555; font-size:13px; text-align:start">
<p style="background-color:#ffffff; color:#555555; font-size:13px; text-align:justify">
	<span><span style="font-size:14px">I,&nbsp;<strong>{{prosecutor.rank}} {{prosecutor.name}}</strong>, affirm that the above-stated facts are true and accurate to the best of my knowledge and belief and that this dismissal is in the best interests of justice, the People, the Defendant, and the public.</span></span>
</p>

<p style="background-color:#ffffff; color:#555555; font-size:13px; text-align:start">
	&nbsp;
</p>

