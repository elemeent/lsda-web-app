			<tr><td height="20" style="border:none;" width="0">&nbsp;</td></tr>
			<tr><td height="20" style="border:none;" width="0">&nbsp;</td></tr>
		</tbody>
	</table>
</div>

<div align="center" style="background-color:#17181f;color:#cbcbcb;font-size:14px;">
	<table border="0" cellpadding="0" cellspacing="0" style="border-collapse:collapse;border-spacing:0px;border:none;">
		<tbody>
			<tr>
				<td style="padding:0in 0.25in;" valign="top" width="721">
					<p style="background-color:#17181f;color:#cbcbcb;font-size:14px;text-align:center;">
						&nbsp;
					</p>

					<p style="background-color:#17181f;color:#cbcbcb;font-size:14px;text-align:center;">
						<u><strong><span style="font-size:20px;text-transform:uppercase;">NOTICE OF APPEARANCE FOR {{attorney.name}}</span></strong></u>
					</p>

					<p style="background-color:#17181f;color:#cbcbcb;font-size:14px;text-align:center;">
						<u><strong><span style="font-size:20px;text-transform:uppercase;">AS COUNSEL OF RECORD FOR {{client.name}}</span></strong></u>
					</p>

					<p style="background-color:#17181f;color:#cbcbcb;font-size:14px;text-align:justify;">
						&nbsp;
					</p>

					<p style="background-color:#17181f;color:#cbcbcb;font-size:14px;text-align:justify;">
						<span><span style="font-size:18px;"><strong>PLEASE TAKE NOTICE THAT </strong>{{attorney.name}}{{#if attorney.showFirm}} of <em>{{attorney.firm}}</em>{{/if}}, who is permitted to practice in this state, hereby enters their appearance as counsel of record on behalf of {{client.title}}, <strong>{{#if client.honorific}}{{client.honorific}} {{/if}}{{client.name}}</strong>. Counsel requests that all pleadings, motions, correspondence, and otherwise, be filed or served to the undersigned at the address provided below, <em>sub poena nullitatis</em>.</span></span>
					</p>

					<p style="background-color:#17181f;color:#cbcbcb;font-size:14px;text-align:justify;">
						&nbsp;
					</p>

					<p style="background-color:#17181f;color:#cbcbcb;font-size:14px;text-align:justify;">
						<span><span style="font-size:18px;">Respectfully submitted,</span></span>
					</p>

					<p style="background-color:#17181f;color:#cbcbcb;font-size:14px;text-align:justify;">
						<span style="font-size:22px;text-transform:uppercase;"><em>{{attorney.name}}</em></span>
					</p>

					<p style="background-color:#17181f;color:#cbcbcb;font-size:14px;text-align:justify;">
						<span style="text-transform:uppercase;">{{filingDate.month}} {{getOrdinal filingDate.day}} {{filingDate.year}}</span>
					</p>

					<p style="background-color:#17181f;color:#cbcbcb;font-size:14px;text-align:justify;">
						<span style="font-size:14px;text-transform:uppercase;">{{attorney.address}}</span>
					</p>
				</td>
			</tr>
		</tbody>
	</table>
</div>
