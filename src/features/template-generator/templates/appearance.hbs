											<p dir="ltr" style="text-align:center;">&nbsp;</p>

											<p dir="ltr" style="text-align:center;">
												<span><span style="font-size:20px;"><b><span style="vertical-align:baseline;">&nbsp; &nbsp; &nbsp; &nbsp; &nbsp; &nbsp; &nbsp; &nbsp;</span></b></span></span>
											</p>
										</td>
									</tr>
								</tbody>
							</table>
						</div>
					</div>
				</td>
				<td height="58" style="border:none;" width="0">&nbsp;</td>
