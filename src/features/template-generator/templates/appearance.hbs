							<span><span style="font-size:20px;">&nbsp; &nbsp;</span></span>
						</p>

						<div align="center" style="background-color:#ffffff;color:#555555;font-size:14px;">
							<table border="0" cellpadding="0" cellspacing="0" style="border-collapse:collapse;border-spacing:0px;">
								<tbody>
									<tr>
										<td style="border-bottom:1pt solid;border-left:none;border-right:1pt solid;border-top:none;padding:0in 5.4pt;" valign="top" width="302">
											<p>
												<span><span style="font-size:20px;">&nbsp;</span></span>
											</p>

											<p>
												<span><span style="font-size:20px;text-transform:uppercase;"><b>{{plaintiff}},</b></span></span>
											</p>

											<p style="text-align:right;">
												<span><span style="font-size:20px;"><b>Plaintiff</b></span></span>
											</p>

											<p style="text-align:center;">
												&nbsp;
											</p>

											<p style="text-align:center;">
												<span><span style="font-size:20px;"><b>-versus-</b></span></span>
											</p>

											<p style="text-align:center;">
												&nbsp;
											</p>

											{{#each defendants}}
											<p>
												<span><span style="font-size:20px;text-transform:uppercase;"><b>{{this.name}},</b></span></span>
											</p>
											{{/each}}

											<p style="text-align:right;">
												<span><span style="font-size:20px;"><b>{{defendantLabel}}.</b></span></span><br>
												<br>
												&nbsp;
											</p>
										</td>
										<td style="padding:0in 5.4pt;" valign="top" width="302">
											<p>
												<span><span style="font-size:20px;">&nbsp;</span></span>
											</p>

											<p dir="ltr">&nbsp;</p>
											<p dir="ltr">&nbsp;</p>
											<p dir="ltr">&nbsp;</p>
											<p dir="ltr">&nbsp;</p>

											<p dir="ltr" style="text-align:center;">
												&nbsp;
											</p>

											<p dir="ltr" style="text-align:center;">
												<span><span style="font-size:20px;"><b><span style="vertical-align:baseline;">Case No. [{{lastTwo filingDate.year}}GJ{{#if isCriminal}}CR{{else}}CC{{/if}}{{zeroFill caseNumber 5}}]</span><br>
												<span style="vertical-align:baseline;">&nbsp;</span></b></span></span>
											</p>

											<p dir="ltr">
												<span><span style="font-size:20px;"><b><span style="vertical-align:baseline;">&nbsp;</span></b></span></span>
