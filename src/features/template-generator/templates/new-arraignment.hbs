		<span>Spoiler</span>
	</div>
	<div class="ipsSpoiler_contents ipsClearfix" data-gramm="false">
		INSERT EXHIBIT CONTENT HERE
	</div>
</div>
<p style="background-color:#ffffff; color:#353c41; font-size:13px; text-align:start">&nbsp;</p>
{{/each}}

<!-- ═══════════════════════════════════════════════════════
     SENTENCING RECOMMENDATIONS
     ═══════════════════════════════════════════════════════ -->
<hr style="background-color:rgba(0, 0, 0, 0.5); color:#cbcbcb; font-size:13px; text-align:start">

<p style="background-color:#ffffff; color:#353c41; font-size:13px; text-align:center">
	<span><span style="font-size:20px"><b><u>Sentencing Recommendations</u></b></span></span>
</p>

<p style="background-color:#ffffff; color:#353c41; font-size:13px; text-align:start">
	<br>
	<span><span style="font-size:16px">Upon conviction, the People hereby demand that the following punishments be imposed:</span></span>
</p>

<p style="background-color:#ffffff; color:#353c41; font-size:13px; text-align:start">
	&nbsp;
</p>

<p style="background-color:#ffffff; color:#353c41; font-size:13px; text-align:start">
	<span><span style="font-size:16px">[{{checkbox sentencing.capitalPunishment}}] - Capital Punishment</span></span>
</p>

<p style="background-color:#ffffff; color:#353c41; font-size:13px; text-align:start">
	<span><span style="font-size:16px">[{{checkbox sentencing.lifeWithoutParole}}] - Life imprisonment without parole</span></span>
</p>

<p style="background-color:#ffffff; color:#353c41; font-size:13px; text-align:start">
	<span><span style="font-size:16px">[{{checkbox sentencing.lifeWithParole}}] - Life imprisonment with parole</span></span>
</p>

<p style="background-color:#ffffff; color:#353c41; font-size:13px; text-align:start">
	<span><span style="font-size:16px">[{{checkbox sentencing.maxStatutory}}] - Maximum statutory sentencing recommendation{{#if sentencing.maxStatutory}} &mdash; <em>{{sentencing.maxStatutory}}</em>{{/if}}</span></span>
</p>

<p style="background-color:#ffffff; color:#353c41; font-size:13px; text-align:start">
	<span><span style="font-size:16px">[{{checkbox sentencing.timeServed}}] - Time served</span></span>
</p>

<p style="background-color:#ffffff; color:#353c41; font-size:13px; text-align:start">
	<span><span style="font-size:16px">[{{checkbox sentencing.other}}] - Other: {{#if sentencing.other}}<u>{{sentencing.other}}</u>{{else}}_____________________{{/if}}</span></span>
</p>

<p style="background-color:#ffffff; color:#353c41; font-size:13px; text-align:start">
	&nbsp;
</p>

<p style="background-color:#ffffff; color:#353c41; font-size:13px; text-align:start">
	<span style="font-size:13px">(( Note: 1 Hour = 1 Day, 1 Day = 1 Month, 1 Month = 1 Year. ))</span>
</p>

<!-- ═══════════════════════════════════════════════════════
     BAIL RECOMMENDATIONS
     ═══════════════════════════════════════════════════════ -->
<hr style="background-color:rgba(0, 0, 0, 0.5); color:#cbcbcb; font-size:13px; text-align:start">

<p style="background-color:#ffffff; color:#353c41; font-size:13px; text-align:center">
	<span><b><span style="font-size:20px"><u>Bail Recommendations</u></span></b></span>
</p>

<p style="background-color:#ffffff; color:#353c41; font-size:13px; text-align:start">
	<br>
	<span><span style="font-size:16px">Upon motion by the People of the State of San Andreas, it is hereby recommended that the Court impose or otherwise uphold the following bail recommendations:</span></span>
</p>

<p style="background-color:#ffffff; color:#353c41; font-size:13px; text-align:start">
	&nbsp;
</p>

{{#unless bail.upholdStationhouse.selected}}<s>{{/unless}}<p style="background-color:#ffffff; color:#353c41; font-size:13px; text-align:start">
	<span>[{{checkbox bail.upholdStationhouse.selected}}] - Uphold Stationhouse Bail &mdash;&nbsp;<u><strong>{{#if bail.upholdStationhouse.value}}${{bail.upholdStationhouse.value}}{{else}}$AMOUNT{{/if}}</strong></u>;&nbsp;or,</span>
</p>{{#unless bail.upholdStationhouse.selected}}</s>{{/unless}}

{{#unless bail.imposeBail.selected}}<s>{{/unless}}<p style="background-color:#ffffff; color:#353c41; font-size:13px; text-align:start">
	<span>[{{checkbox bail.imposeBail.selected}}] - Impose Bail &mdash;&nbsp;<u><strong>{{#if bail.imposeBail.value}}${{bail.imposeBail.value}}{{else}}$AMOUNT{{/if}}</strong></u>.</span>
</p>{{#unless bail.imposeBail.selected}}</s>{{/unless}}

{{#unless bail.imposeBail.abstainAlcohol}}<s>{{/unless}}<p style="background-color:#ffffff; color:#353c41; font-size:12px; text-align:start">
	<span>&nbsp; &nbsp; [{{checkbox bail.imposeBail.abstainAlcohol}}] - Abstain from excessive use of alcohol and any use of a controlled substance without a prescription.</span>
</p>{{#unless bail.imposeBail.abstainAlcohol}}</s>{{/unless}}

{{#unless bail.imposeBail.appearCourt}}<s>{{/unless}}<p style="background-color:#ffffff; color:#353c41; font-size:12px; text-align:start">
	<span>&nbsp; &nbsp; [{{checkbox bail.imposeBail.appearCourt}}] - Appear before the court on each date the case is assigned to call.</span>
</p>{{#unless bail.imposeBail.appearCourt}}</s>{{/unless}}

{{#unless bail.imposeBail.abstainCriminalActivity}}<s>{{/unless}}<p style="background-color:#ffffff; color:#353c41; font-size:12px; text-align:start">
	<span>&nbsp; &nbsp; [{{checkbox bail.imposeBail.abstainCriminalActivity}}] - Abstain from criminal activity while subject to the bail order.</span>
</p>{{#unless bail.imposeBail.abstainCriminalActivity}}</s>{{/unless}}

{{#unless bail.imposeBail.wearAnkleMonitor}}<s>{{/unless}}<p style="background-color:#ffffff; color:#353c41; font-size:12px; text-align:start">
	<span>&nbsp; &nbsp; [{{checkbox bail.imposeBail.wearAnkleMonitor}}] - Wear an ankle monitor at all times.</span>
</p>{{#unless bail.imposeBail.wearAnkleMonitor}}</s>{{/unless}}

{{#unless bail.imposeBail.surrenderFirearms}}<s>{{/unless}}<p style="background-color:#ffffff; color:#353c41; font-size:12px; text-align:start">
	<span>&nbsp; &nbsp; [{{checkbox bail.imposeBail.surrenderFirearms}}] - Surrender any illegal or legally owned firearms to the respective agency.</span>
</p>{{#unless bail.imposeBail.surrenderFirearms}}</s>{{/unless}}

{{#unless bail.imposeBail.possessCellPhone}}<s>{{/unless}}<p style="background-color:#ffffff; color:#353c41; font-size:12px; text-align:start">
	<span>&nbsp; &nbsp; [{{checkbox bail.imposeBail.possessCellPhone}}] - Possess and keep on at all times an active cell phone with its number registered to Defendant.</span>
</p>{{#unless bail.imposeBail.possessCellPhone}}</s>{{/unless}}

{{#unless bail.imposeBail.refrainContact}}<s>{{/unless}}<p style="background-color:#ffffff; color:#353c41; font-size:12px; text-align:start">
	<span>&nbsp; &nbsp; [{{checkbox bail.imposeBail.refrainContact}}] - Refrain from contact with any victim/witness relating to this arrest.</span>
</p>{{#unless bail.imposeBail.refrainContact}}</s>{{/unless}}

{{#unless bail.imposeBail.refrainGang}}<s>{{/unless}}<p style="background-color:#ffffff; color:#353c41; font-size:12px; text-align:start">
	<span>&nbsp; &nbsp; [{{checkbox bail.imposeBail.refrainGang}}] - Refrain from associating with known gang members or violent felons.</span>
</p>{{#unless bail.imposeBail.refrainGang}}</s>{{/unless}}

{{#unless bail.imposeBail.other}}<s>{{/unless}}<p style="background-color:#ffffff; color:#353c41; font-size:12px; text-align:start">
	<span>&nbsp; &nbsp; [{{checkbox bail.imposeBail.other}}] - Other: {{#if bail.imposeBail.other}}<u>{{bail.imposeBail.other}}</u>{{else}}_____________________{{/if}}</span>
</p>{{#unless bail.imposeBail.other}}</s>{{/unless}}

{{#unless bail.orderDetention.selected}}<s>{{/unless}}<p style="background-color:#ffffff; color:#353c41; font-size:13px; text-align:start">
	<span>[{{checkbox bail.orderDetention.selected}}] - Order Defendant&#39;s Detention.</span>
</p>{{#unless bail.orderDetention.selected}}</s>{{/unless}}

{{#unless bail.orderDetention.felonyViolence}}<s>{{/unless}}<p style="background-color:#ffffff; color:#353c41; font-size:12px; text-align:start">
	<span>&nbsp; &nbsp; [{{checkbox bail.orderDetention.felonyViolence}}] - The defendant is charged with a felony crime of violence and has over 30 criminal points on record.</span>
</p>{{#unless bail.orderDetention.felonyViolence}}</s>{{/unless}}

{{#unless bail.orderDetention.maxSentence}}<s>{{/unless}}<p style="background-color:#ffffff; color:#353c41; font-size:12px; text-align:start">
	<span>&nbsp; &nbsp; [{{checkbox bail.orderDetention.maxSentence}}] - The defendant is charged with an offense for which the maximum sentence is life imprisonment or death.</span>
</p>{{#unless bail.orderDetention.maxSentence}}</s>{{/unless}}

{{#unless bail.orderDetention.historyViolatingBail}}<s>{{/unless}}<p style="background-color:#ffffff; color:#353c41; font-size:12px; text-align:start">
	<span>&nbsp; &nbsp; [{{checkbox bail.orderDetention.historyViolatingBail}}] - The defendant has a history of violating bail conditions.</span>
</p>{{#unless bail.orderDetention.historyViolatingBail}}</s>{{/unless}}

{{#unless bail.orderDetention.threatenWitness}}<s>{{/unless}}<p style="background-color:#ffffff; color:#353c41; font-size:12px; text-align:start">
	<span>&nbsp; &nbsp; [{{checkbox bail.orderDetention.threatenWitness}}] - There exists a serious risk that the defendant will threaten, injure, or intimidate a prospective witness.</span>
</p>{{#unless bail.orderDetention.threatenWitness}}</s>{{/unless}}

{{#unless bail.orderDetention.noBailConditions}}<s>{{/unless}}<p style="background-color:#ffffff; color:#353c41; font-size:12px; text-align:start">
	<span>&nbsp; &nbsp; [{{checkbox bail.orderDetention.noBailConditions}}] - The People believe that no condition or combination of conditions will reasonably assure the defendant&#39;s appearance as required and the safety of any person or the community.</span>
</p>{{#unless bail.orderDetention.noBailConditions}}</s>{{/unless}}

{{#unless bail.orderDetention.other}}<s>{{/unless}}<p style="background-color:#ffffff; color:#353c41; font-size:12px; text-align:start">
	<span>&nbsp; &nbsp; [{{checkbox bail.orderDetention.other}}] - Other: {{#if bail.orderDetention.other}}<u>{{bail.orderDetention.other}}</u>{{else}}_____________________{{/if}}</span>
</p>{{#unless bail.orderDetention.other}}</s>{{/unless}}

<p style="background-color:#ffffff; color:#353c41; font-size:13px; text-align:start">
	&nbsp;
</p>

{{#if prayer}}
<!-- ═══════════════════════════════════════════════════════
     PRAYER FOR RELIEF
     ═══════════════════════════════════════════════════════ -->
<hr style="background-color:rgba(0, 0, 0, 0.5); color:#cbcbcb; font-size:13px; text-align:start">

<p style="background-color:#ffffff; color:#353c41; font-size:13px; text-align:center">
	<span><span style="font-size:20px"><b><u>Prayer for Relief</u></b></span></span>
</p>

<p style="background-color:#ffffff; color:#353c41; font-size:14px; text-align:justify">
	&nbsp;
</p>

<p style="background-color:#ffffff; color:#353c41; font-size:16px; text-align:justify">
	<strong>WHEREFORE</strong>, the People of the State of San Andreas, by and through the undersigned counsel, respectfully pray that this Honorable Court:
</p>

<p style="background-color:#ffffff; color:#353c41; font-size:14px; text-align:justify">
	&nbsp;
</p>

<p style="background-color:#ffffff; color:#353c41; font-size:16px; text-align:justify; padding:0 12px; border-left:3px solid #353c41; margin-left:8px">
	{{nl2br prayer}}
</p>

<p style="background-color:#ffffff; color:#353c41; font-size:14px; text-align:justify">
	&nbsp;
</p>
{{/if}}

